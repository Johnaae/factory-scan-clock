{
  "name": "factory-scan-clock",
  "version": "1.0.0",
  "description": "Lightweight barcode employee IN/OUT clock for small factory offices",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "backup": "node scripts/backup.js",
    "backup:daily": "node scripts/backup.js --daily",
    "backup:pg": "node scripts/pg-backup.js",
    "restore:pg": "node scripts/pg-restore.js --latest --interactive",
    "backup:prune": "node scripts/prune-pg-backups.js --keep 30",
    "test:finish-workflow": "node scripts/test-finish-workflow.js",
    "badges:pdf": "node scripts/print-employee-badges.js --active"
  },
  "keywords": [
    "barcode",
    "clock",
    "postgres",
    "express"
  ],
  "license": "MIT",
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || ^22.0.0 || ^24.0.0"
  },
  "dependencies": {
    "bwip-js": "^4.11.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "pdfkit": "^0.15.2",
    "pg": "^8.20.0"
  }
}
