{
  "name": "factory-scan-clock",
  "version": "1.0.0",
  "description": "Lightweight barcode employee IN/OUT clock for small factory offices",
  "main": "server.js",
  "scripts": {
    "dev": "node -r dotenv/config server.js",
    "start": "node server.js",
    "migrate": "node -r dotenv/config scripts/migrate.js",
    "seed": "node -r dotenv/config scripts/seed.js",
    "backup": "node -r dotenv/config scripts/backup.js",
    "backup:daily": "node -r dotenv/config scripts/backup.js --daily"
  },
  "keywords": [
    "barcode",
    "clock",
    "postgres",
    "express"
  ],
  "license": "MIT",
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || ^22.0.0 || ^24.0.0"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "pdfkit": "^0.15.2",
    "pg": "^8.20.0"
  }
}
