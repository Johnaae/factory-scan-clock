# Local LAN / internal testing — copy to .env.local (overrides .env)
DATABASE_URL=postgresql://postgres:password@localhost:5432/factory_scan_clock
SESSION_SECRET=change-me-local-secret
NODE_ENV=development
OWNER_PASSWORD=change-me
INTERNAL_LAN_MODE=true

# Optional if pg_dump is not on PATH:
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe
