# Neon / Vercel production (set in Vercel dashboard — do not use INTERNAL_LAN_MODE)
DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
SESSION_SECRET=
NODE_ENV=production
OWNER_PASSWORD=

# Local LAN: copy .env.local.example → .env.local (see LOCAL_LAN_SETUP.md)
# INTERNAL_LAN_MODE=true

# Optional: path to pg_dump for PostgreSQL backups (System page / npm run backup:pg)
# Windows example:
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe
# PG_RESTORE_PATH=C:\Program Files\PostgreSQL\16\bin\pg_restore.exe
